-- Bloxy Bingo Auto-Clicker + GUI (Mobile Friendly w/ Toggle)
-- Updated for 2026 - Toggle ON/OFF, Auto-Mark Numbers, Auto-Claim BINGO!
-- WARNING: Violates Roblox TOS - Use alt account, ban risk!

local UIS = game:GetService("UserInputService")
local inputman = game:GetService("VirtualInputManager")
local RunService = game:GetService("RunService")

-- Mobile draggable button (toggles GUI w/ LeftControl sim)
if UIS.TouchEnabled then
    local tuff1 = Instance.new("ScreenGui", game.Players.LocalPlayer.PlayerGui)
    tuff1.ResetOnSpawn = false
    local tufff = Instance.new("ImageButton", tuff1)
    tufff.Size = UDim2.new(0, 60, 0, 60)
    tufff.Position = UDim2.new(0, 50, 0.5, -30)
    tufff.BackgroundTransparency = 1
    tufff.Draggable = true 
    local path = "saturin.png"
    if not isfile(path) then writefile(path, game:HttpGet("https://www.pompomsaturin.site/pfp%20(1).png")) end
    tufff.Image = getcustomasset(path)
    tufff.MouseButton1Click:Connect(function()
        inputman:SendKeyEvent(true, Enum.KeyCode.LeftControl, false, game)
        task.wait()
        inputman:SendKeyEvent(false, Enum.KeyCode.LeftControl, false, game)
    end)
end

-- Flux UI Library (works on mobile/PC)
local lib = loadstring(game:HttpGet("https://raw.githubusercontent.com/dawid-scripts/UI-Libs/main/fluxlib.txt"))()
local win = lib:Window("Bloxy Bingo Auto", "Mobile + Toggle | GitHub ver.", Color3.fromRGB(255, 110, 48), Enum.KeyCode.LeftControl)

local autoclickEnabled = false

local main = win:Tab("Main", "http://www.roblox.com/asset/?id=6022668888")

-- TOGGLE for Auto Click + Auto Bingo
main:Toggle("Auto Click + Auto Bingo", "Auto-marks numbers & claims BINGO! (Toggle ON/OFF)", function(state)
    autoclickEnabled = state
    lib:Notification("Auto " .. (state and "ON" or "OFF"), "Toggled!")
end)

-- Spawn the loop (runs always, checks flag)
spawn(function()
    local claimb = game.Players.LocalPlayer.PlayerGui.Bingo.StaticDisplayArea.Cards.PlayerArea.Cards.Container.SubContainer
    
    local function click(btn)
        if not btn then return end
        for _, c in pairs(getconnections(btn.MouseButton1Click)) do c:Fire() end
        for _, c in pairs(getconnections(btn.MouseButton1Down)) do c:Fire() end
        for _, c in pairs(getconnections(btn.Activated)) do c:Fire() end
    end
    
    while true do
        if autoclickEnabled then
            task.wait(0.03)  -- Fast loop when ON
            local claimc = claimb:FindFirstChild("Blocks") and claimb.Blocks.Block or claimb.VerticalScroll.Cards
            local claim = claimb.Buttons.ClaimButton
            if claimc and claim then
                for _, card in pairs(claimc:GetChildren()) do
                    if card:IsA("Frame") then
                        local content = card:FindFirstChild("Content")
                        local nums = content and content:FindFirstChild("Numbers")
                        if nums then
                            for _, n in pairs(nums:GetChildren()) do
                                click(n)
                                task.wait()
                            end
                        end
                        local toGo = card:FindFirstChild("ToGo")
                        if toGo and toGo.ToGoText.Text == "BINGO!" then
                            click(claim)
                        end
                    end
                end
            end
        else
            task.wait(1)  -- Slow wait when OFF (saves perf)
        end
    end
end)

lib:Notification("Loaded! 🚀", "Tap draggable icon on mobile / Left Ctrl on PC")

-- Player Tab
local Player = win:Tab("Player", "http://www.roblox.com/asset/?id=6023426915")
Player:Slider("WalkSpeed", "Faster walking", 16, 200, 16, function(t)
    local hum = game.Players.LocalPlayer.Character and game.Players.LocalPlayer.Character:FindFirstChild("Humanoid")
    if hum then hum.WalkSpeed = t end
end)
Player:Slider("JumpPower", "Higher jumps", 50, 200, 50, function(t)
    local hum = game.Players.LocalPlayer.Character and game.Players.LocalPlayer.Character:FindFirstChild("Humanoid")
    if hum then hum.JumpPower = t end
end)

local noclipEnabled = false
Player:Toggle("Noclip", "No clip through walls", false, function(state)
    noclipEnabled = state
end)
RunService.Stepped:Connect(function()
    if noclipEnabled then
        local char = game.Players.LocalPlayer.Character
        if char then
            for _, part in pairs(char:GetDescendants()) do
                if part:IsA("BasePart") and part.CanCollide then
                    part.CanCollide = false
                end
            end
        end
    end
end)

