-- SUPER SIMPLE TEST: Just shows a "HI" button
-- If you see a blue button saying "HI" → your executor works fine for GUIs!
-- If NOT → problem is executor/injection, not the code.

local player = game.Players.LocalPlayer
local playerGui = player:WaitForChild("PlayerGui")

local screenGui = Instance.new("ScreenGui")
screenGui.Name = "TestGui"
screenGui.ResetOnSpawn = false
screenGui.Parent = playerGui

local button = Instance.new("TextButton")
button.Name = "TestButton"
button.Parent = screenGui
button.Size = UDim2.new(0, 200, 0, 100)
button.Position = UDim2.new(0.5, -100, 0.5, -50)  -- centered on screen
button.BackgroundColor3 = Color3.fromRGB(0, 170, 255)  -- nice blue
button.BorderSizePixel = 0
button.Font = Enum.Font.GothamBold
button.Text = "HI"
button.TextColor3 = Color3.fromRGB(255, 255, 255)
button.TextSize = 60

local corner = Instance.new("UICorner")
corner.CornerRadius = UDim2.new(0, 12, 0, 12)
corner.Parent = button

print("Test button created! Look for a big blue 'HI' in the middle of your screen.")
