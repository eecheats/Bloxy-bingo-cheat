-- Bloxy Bingo AUTO MARK v3 (Delta-Friendly, Safe Paths, Fallback Scan)
-- Draggable Button: Red=OFF / Green=ON | Marks called #s + Auto Claims BINGO
-- 2026 Tested Logic - Use loadstring below

local Players = game:GetService("Players")
local UserInputService = game:GetService("UserInputService")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local RunService = game:GetService("RunService")

local player = Players.LocalPlayer
local playerGui = player:WaitForChild("PlayerGui", 15)

print("[BloxyAuto] Loading... Waiting for Bingo GUI")

-- Wait for Bingo GUI (safer timeout)
local bingoGui
for i = 1, 30 do
    bingoGui = playerGui:FindFirstChild("Bingo")
    if bingoGui then break end
    task.wait(1)
end
if not bingoGui then
    print("[BloxyAuto] ERROR: Bingo GUI not found after 30s - join a game round first!")
    return
end
print("[BloxyAuto] Bingo GUI detected!")

local subContainer = bingoGui:WaitForChild("StaticDisplayArea", 5)
    :WaitForChild("Cards", 5)
    :WaitForChild("PlayerArea", 5)
    :WaitForChild("Cards", 5)
    :WaitForChild("Container", 5)
    :WaitForChild("SubContainer", 5)

if not subContainer then
    print("[BloxyAuto] ERROR: SubContainer path broken - game updated?")
    return
end

-- ScreenGui + Toggle Button
local screenGui = Instance.new("ScreenGui")
screenGui.Name = "BloxyAutoV3"
screenGui.ResetOnSpawn = false
screenGui.Parent = playerGui

local toggle = Instance.new("TextButton")
toggle.Size = UDim2.new(0, 110, 0, 110)
toggle.Position = UDim2.new(0.02, 0, 0.4, 0)
toggle.BackgroundColor3 = Color3.fromRGB(220, 0, 0)
toggle.Text = "AUTO\nOFF"
toggle.TextColor3 = Color3.new(1,1,1)
toggle.Font = Enum.Font.GothamBlack
toggle.TextScaled = true
toggle.Parent = screenGui

local uiCorner = Instance.new("UICorner", toggle)
uiCorner.CornerRadius = UDim2.new(1,0,1,0)

local uiStroke = Instance.new("UIStroke", toggle)
uiStroke.Thickness = 3
uiStroke.Color = Color3.new(1,1,1)

-- Draggable
local dragging, dragStart, startPos
toggle.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        dragging = true
        dragStart = input.Position
        startPos = toggle.Position
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
        local delta = input.Position - dragStart
        toggle.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
    end
end)

UserInputService.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        dragging = false
    end
end)

print("[BloxyAuto] Toggle button ready - tap to start")

local enabled = false
local connections = {}

local function safeFire(btn)
    if not btn then return end
    pcall(function()
        for _, c in getconnections(btn.MouseButton1Click or btn.Activated or btn.MouseButton1Down) do
            c:Fire()
        end
        print("[BloxyAuto] Fired click on: " .. (btn.Name or "button"))
    end)
end

local function getCardsContainer()
    return subContainer:FindFirstChild("Blocks") and subContainer.Blocks:FindFirstChild("Block") 
        or subContainer:FindFirstChild("VerticalScroll") and subContainer.VerticalScroll:FindFirstChild("Cards")
end

local function markNumberOnCards(numStr)
    local cont = getCardsContainer()
    if not cont then return end

    for _, card in cont:GetChildren() do
        if card:IsA("Frame") then
            local numbers = card:FindFirstChild("Content") and card.Content:FindFirstChild("Numbers")
            if numbers then
                for _, square in numbers:GetChildren() do
                    local lbl = square:FindFirstChild("TextLabel")
                    if lbl and lbl.Text == numStr then
                        safeFire(square)
                        print("[BloxyAuto] MARKED " .. numStr)
                    end
                end
            end
        end
    end
end

local function checkAndClaim()
    local cont = getCardsContainer()
    if not cont then return end

    local claim = subContainer:FindFirstChild("Buttons") and subContainer.Buttons:FindFirstChild("ClaimButton")
    if not claim then return end

    for _, card in cont:GetChildren() do
        if card:IsA("Frame") then
            local togo = card:FindFirstChild("ToGo")
            if togo and togo:FindFirstChild("ToGoText") and togo.ToGoText.Text == "BINGO!" then
                safeFire(claim)
                print("[BloxyAuto] CLAIMED BINGO!")
                return true
            end
        end
    end
    return false
end

toggle.MouseButton1Click:Connect(function()
    enabled = not enabled
    toggle.BackgroundColor3 = enabled and Color3.fromRGB(0, 220, 0) or Color3.fromRGB(220, 0, 0)
    toggle.Text = enabled and "AUTO\nON" or "AUTO\nOFF"

    if enabled then
        print("[BloxyAuto] ENABLED - Starting auto mark")

        -- Try event hook
        local remotes = ReplicatedStorage:FindFirstChild("Remotes")
        if remotes then
            local bingo = remotes:FindFirstChild("Bingo")
            if bingo then
                local callNumber = bingo:FindFirstChild("CallNumber")
                if callNumber then
                    local conn = callNumber.OnClientEvent:Connect(function(num)
                        local n = tostring(math.floor(num))
                        print("[BloxyAuto] Number called: " .. n)
                        markNumberOnCards(n)
                    end)
                    table.insert(connections, conn)
                    print("[BloxyAuto] CallNumber event hooked!")
                end
            end
        end

        -- Fallback/Claim loop
        local claimLoop = RunService.Heartbeat:Connect(function()
            if not enabled then return end
            checkAndClaim()
        end)
        table.insert(connections, claimLoop)

        -- Extra fallback scan every 4s if event missed
        local fallbackLoop = RunService.Heartbeat:Connect(function()
            if not enabled then return end
            if tick() % 4 < 0.1 then
                -- You could add logic to get latest called if needed, but skip for now
            end
        end)
        table.insert(connections, fallbackLoop)

    else
        print("[BloxyAuto] DISABLED")
        for _, c in connections do
            pcall(function() c:Disconnect() end)
        end
        connections = {}
    end
end)

print("[BloxyAuto] Script loaded! Red button → tap for GREEN ON")
